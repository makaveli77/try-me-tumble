# ==========================================
# Database Credentials (PostgreSQL)
# ==========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=try-me-tumble

# ==========================================
# External Services
# ==========================================
# Used in docker-compose.yml and testing
REDIS_CONNECTION="127.0.0.1:6379"

# ==========================================
# App Settings (.NET)
# ==========================================
# ASP.NET Core Runtime Environment (Development, Staging, Production)
ASPNETCORE_ENVIRONMENT=Development
# Internal Port mapping mapping
API_PORT=5200
# Long secure key used in Program.cs for JwtBearer authentication
JWT_TOKEN=ThisIsALongAndSecureKeyForJWTTokenGenerationAtLeast64CharsLong!!

# ==========================================
# Deployment Secrets (Optional local - required for CI)
# ==========================================
# Used by scripts/deploy-production.sh and deploy-staging.sh
DEPLOY_TOKEN=
DEPLOY_WEBHOOK_URL_STAGING=
DEPLOY_WEBHOOK_URL=

# ==========================================
# Docker Run configuration 
# ==========================================
# User ID for container runtime (defined in Dockerfile)
APP_UID=1000
# ==========================================
# Data Seeding (Local Development)
# ==========================================
# Number of websites to generate via Bogus on setup (e.g. 20000, 1000)
SEED_COUNT=20000

